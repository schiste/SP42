#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ "${SP42_SKIP_GIT_HOOKS:-0}" == "1" ]]; then
  printf 'SP42 pre-commit hook skipped because SP42_SKIP_GIT_HOOKS=1.\n'
  exit 0
fi

# A change is "docs-only" when every modified path ends in .md/.log/.txt; such
# changes skip the compile-heavy steps. Anything else, or an empty/undetectable
# set, runs the full checks (fail safe).
all_docs() {
  [[ -n "$1" ]] || return 1
  local f
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    case "$f" in
      *.md|*.log|*.txt) ;;
      *) return 1 ;;
    esac
  done <<< "$1"
  return 0
}

# No --diff-filter: deletions must be classified too, so deleting a non-docs
# file (e.g. a source module) still forces the full checks.
staged="$(git diff --cached --name-only)"
docs_only=0
if all_docs "$staged"; then docs_only=1; fi

printf '\n== SP42 pre-commit: staged whitespace ==\n'
git diff --cached --check

printf '\n== SP42 pre-commit: working-tree whitespace ==\n'
git diff --check

printf '\n== SP42 pre-commit: docs consistency ==\n'
bash scripts/check-doc-consistency.sh

printf '\n== SP42 pre-commit: markdown link check ==\n'
./scripts/check-links.sh

if [[ "$docs_only" == "1" ]]; then
  printf '\nSP42 pre-commit: docs-only change (.md/.log/.txt) — skipping rustfmt, release-tree audit, and focused build.\n'
  printf 'SP42 pre-commit checks passed.\n'
  exit 0
fi

printf '\n== SP42 pre-commit: rustfmt ==\n'
cargo fmt --all -- --check

printf '\n== SP42 pre-commit: forbidden-pattern guard (added lines, §5.3) ==\n'
./scripts/check-forbidden-patterns.sh --staged

printf '\n== SP42 pre-commit: clippy (changed crates, pedantic = deny) ==\n'
changed_crates="$(git diff --cached --name-only \
  | sed -nE 's#^crates/([^/]+)/.*#\1#p; s#^(xtask)/.*#\1#p' | sort -u)"
if [[ -n "$changed_crates" ]]; then
  clippy_pkgs=()
  while IFS= read -r c; do [[ -n "$c" ]] && clippy_pkgs+=(-p "$c"); done <<< "$changed_crates"
  cargo clippy "${clippy_pkgs[@]}" --all-targets --all-features -- -D warnings
else
  printf 'no crate sources changed — skipping scoped clippy.\n'
fi

printf '\n== SP42 pre-commit: release tree audit ==\n'
./scripts/audit-release-tree.sh

printf '\n== SP42 pre-commit: focused checks ==\n'
./scripts/check-focused.sh

printf '\nSP42 pre-commit checks passed.\n'
