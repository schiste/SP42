#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if [[ "${SP42_SKIP_GIT_HOOKS:-0}" == "1" ]]; then
  printf 'SP42 pre-push hook skipped because SP42_SKIP_GIT_HOOKS=1.\n'
  exit 0
fi

# Determine whether every pushed commit touches only docs (.md/.log/.txt).
# Ref updates arrive on stdin; on any non-docs file or an unresolvable range,
# fall through to the full checks (fail safe).
all_docs() {
  [[ -n "$1" ]] || return 1
  local f
  while IFS= read -r f; do
    [[ -n "$f" ]] || continue
    case "$f" in
      *.md|*.log|*.txt) ;;
      *) return 1 ;;
    esac
  done <<< "$1"
  return 0
}

docs_only=1
saw_ref=0
zero="0000000000000000000000000000000000000000"
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [[ -z "${local_sha:-}" ]] && continue
  [[ "$local_sha" == "$zero" ]] && continue   # branch deletion
  saw_ref=1
  if [[ "$remote_sha" == "$zero" ]]; then
    base="$(git merge-base origin/main "$local_sha" 2>/dev/null || true)"
    [[ -z "$base" ]] && { docs_only=0; break; }
    range="$base..$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi
  files="$(git diff --name-only "$range" 2>/dev/null || true)"
  if ! all_docs "$files"; then docs_only=0; break; fi
done
[[ "$saw_ref" == "0" ]] && docs_only=0

if [[ "$docs_only" == "1" ]]; then
  printf '\n== SP42 pre-push: docs consistency ==\n'
  bash scripts/check-doc-consistency.sh
  printf '\nSP42 pre-push: docs-only push (.md/.log/.txt) — skipping release-tree audit and ci-all.\n'
  printf 'SP42 pre-push checks passed.\n'
  exit 0
fi

printf '\n== SP42 pre-push: release tree audit ==\n'
./scripts/audit-release-tree.sh

printf '\n== SP42 pre-push: full CI-shaped checks ==\n'
./scripts/ci-all.sh

printf '\n== SP42 pre-push: supply-chain (cargo-deny + cargo-audit) ==\n'
./scripts/check-supply-chain.sh

printf '\n== SP42 pre-push: coverage (sp42-core lines >= 90%%) ==\n'
./scripts/check-coverage.sh

# Wasm size is enforced in CI and the release flow, not here: it requires an
# optimized (web-release) rebuild, which would be punishing on every push.
printf '\n== SP42 pre-push: forbidden-pattern guard (added lines vs origin/main) ==\n'
base="$(git merge-base origin/main HEAD 2>/dev/null || true)"
if [[ -n "$base" ]]; then
  ./scripts/check-forbidden-patterns.sh --range "$base..HEAD"
else
  printf 'no origin/main merge-base — running staged-mode guard.\n'
  ./scripts/check-forbidden-patterns.sh --staged
fi

printf '\nSP42 pre-push checks passed.\n'
